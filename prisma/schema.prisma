// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Project {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // 원본 파일
  originalFileName String
  originalFileUrl  String  @default("") // 더 이상 사용하지 않음 (하위 호환용)
  fileType         String  // "docx" | "pdf"
  fileSize         Int
  originalText     String? // 업로드 시 메모리에서 추출한 원문 텍스트

  // 템플릿 설정
  writingStyle     String  @default("professional") // professional | casual | academic | storytelling
  tocFormat        String  @default("numbered")     // numbered | bulleted | none
  sentenceStructure String @default("medium")       // short | medium | long

  // 변환 상태 (PENDING | PROCESSING | COMPLETED | FAILED)
  status      String  @default("PENDING")
  progress    Int     @default(0) // 0~100

  // 2단계: 내용 분석 결과 (JSON)
  analysisData  String?  // { summary, targetAudiences[] }
  targetAudience String? // 확정 타겟층

  // 3단계: 확정 목차 (JSON 문자열)
  tocData       String?

  // 4단계: 챕터별 생성 결과 (클라이언트 오케스트레이션용 JSON)
  chaptersJson  String?

  // 결과물
  ebookTitle    String?
  ebookContent  String?
  ebookFileUrl  String?
  pageCount     Int?
  wordCount     Int?
  errorMessage  String?
}

// 백그라운드 AI 작업 추적 (분석, 제목/목차 추천)
model Job {
  id        String   @id @default(cuid())
  type      String   // "analyze" | "recommend"
  projectId String
  status    String   @default("pending")
  // analyze:   pending → running → summary_done → done | failed
  // recommend: pending → running → titles_done  → done | failed
  result    String?  // JSON: 단계별 누적 결과
  error     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
